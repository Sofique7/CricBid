rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // CricBid general rules
    // Allow anyone to read data so the app displays players, teams, and auction states in real time.
    // Deny all writes directly from clients. All updates must be authorized via server-side Admin SDK.
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
